# =============================================================================
# hh-research Web (Vite) — переменные окружения (скопировать в .env)
# =============================================================================

# Хост и порт приложения.
VITE_APP_HOST=hh-research.loc
VITE_APP_PORT=3001

# Базовый URL REST API со суффиксом /api (axios baseURL).
# Локально с доменами из AGENTS.md:
VITE_API_URL=http://api.hh-research.loc:3000/api

# Если фронт открываете как http://localhost:3001, используйте тот же хост, что и у API, например:
# VITE_API_URL=http://localhost:3000/api
