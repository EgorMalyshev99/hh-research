# =============================================================================
# hh-research API — переменные окружения (скопировать в .env)
# =============================================================================

# --- PostgreSQL (Drizzle) ---
# Локально (без Docker API): localhost. В Docker API: host должен быть postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hh_research

# --- JWT (обязательно ≥ 32 символов для секретов) ---
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
# Длительность access-токена (строка для jsonwebtoken, напр. 15m, 1h)
JWT_ACCESS_EXPIRES_IN=15m
# Длительность refresh (httpOnly cookie)
JWT_REFRESH_EXPIRES_IN=7d

# --- HTTP ---
PORT=3000
NODE_ENV=development
# Origin фронта для CORS (точное совпадение)
FRONTEND_URL=http://hh-research.loc:3001
# Базовый URL HH API
HH_API_BASE=https://api.hh.ru
# Обязательный заголовок для HH API
HH_USER_AGENT=hh-research-api/1.0 (local-dev)

# --- LLM: таймаут одного HTTP-запроса к провайдеру (мс), скоринг / письма ---
LLM_REQUEST_TIMEOUT_MS=120000

# --- Внешние API (опционально; иначе дефолты из config.schema.ts) ---
# GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# GROQ_API_BASE=https://api.groq.com/openai/v1

# --- Ключи LLM (в UI выбирается провайдер; ключи только здесь) ---
GEMINI_API_KEY=
# OPENROUTER_API_KEY=
# Заголовок HTTP-Referer для OpenRouter (рекомендуется URL репозитория или сайта)
# OPENROUTER_HTTP_REFERER=https://github.com/your/hh-research
# GROQ_API_KEY=

# --- Telegram (бот уведомлений) ---
# Токен бота от @BotFather
# TELEGRAM_BOT_TOKEN=
# Chat ID группового чата для алертов по ошибкам API (может быть отрицательным)
# TELEGRAM_ERRORS_CHAT_ID=
# Сколько вакансий максимум отправлять пользователю в личку за один прогон
TELEGRAM_VACANCY_DIGEST_LIMIT=20
