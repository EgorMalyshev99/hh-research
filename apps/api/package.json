  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.20.6",
    "typescript": "5.9.3"
  }
