{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "build:vercel": "pnpm drizzle:migrate && nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
