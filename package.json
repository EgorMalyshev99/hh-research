{
  "name": "hh-research",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,vue,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,md,json}\""
  },
  "devDependencies": {
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "prettier-plugin-classnames": "^0.10.1",
    "prettier-plugin-merge": "^0.10.1",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "turbo": "^2.9.6",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "esbuild",
      "unrs-resolver",
      "vue-demi"
    ]
  }
}
